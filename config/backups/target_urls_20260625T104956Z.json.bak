        },
        "out_of_pocket_max": {
          "css_selector": "[data-oop-max], .out-of-pocket",
          "type": "float",
          "regex_pattern": "\\$(\\d+(?:,\\d{3})*)"
        },
        "copay_specialist": {
          "css_selector": "[data-specialist-copay]",
          "type": "string"
        },
        "coinsurance_after_deductible": {
          "css_selector": ".coinsurance-rate",
          "type": "string",
          "regex_pattern": "(\\d+)%"
        },
        "drug_coverage": {
          "css_selector": "[data-drug-formulary]",
          "type": "string"
        }
      },
      "request_config": {
        "min_delay_ms": 250,
        "max_delay_ms": 700,
        "referer": "https://www.bing.com/search?q=aetna+plans+pennsylvania",
        "accept_language": "en-US,en;q=0.9,es;q=0.8"
      },
      "target_metrics": [
        "monthly_premium",
        "annual_deductible",
        "out_of_pocket_max",
        "copay_specialist",
        "coinsurance_rate",
        "drug_tier_coverage"
      ],
      "notes": "Aetna operates HMO and PPO plans in PA. Heavy JavaScript rendering required. Aggressive bot detection—use residential proxies. High 429 error rates."
    },

