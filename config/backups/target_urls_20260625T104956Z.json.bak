  ],

  "scrape_parameters": {
    "user_agent_pool": [
      "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36",
      "Mozilla/5.0 (Macintosh; Intel Mac OS X 13_5_2) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/16.6 Safari/605.1.15",
      "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36"
    ],
    "proxy_strategy": "rotating_residential",
    "max_concurrent_requests": 6,
    "retry_policy": {
      "max_retries": 4,
      "backoff_factor": 2,
      "status_codes_to_retry": [429, 502, 503, 504]
    },
    "javascript_render": true,
    "stealth_mode": {
      "canvas_fingerprint": false,
      "webgl_fingerprint": false,
      "navigator_properties": true
    },
    "timeout_ms": 30000
  },

  "extraction_defaults": {
    "date_format": "YYYY-MM-DD",
    "currency": "USD",
    "decimal_separator": ".",
    "thousand_separator": ",",
    "missing_value_placeholder": "N/A"
  },

  "data_validation": {
    "numeric_ranges": {
      "monthly_premium": { "min": 0, "max": 2000 },
      "annual_deductible": { "min": 0, "max": 20000 },
      "out_of_pocket_max": { "min": 0, "max": 25000 }
    },
    "allowed_plan_types": ["HMO", "PPO", "EPO", "POS"],
    "boolean_fields": ["humana_rewards_eligible", "tobacco_user"],
    "string_length_limits": {
      "plan_type": { "max": 10 },
      "network_type": { "max": 20 },
      "mental_health_copay": { "max": 10 }
    }
  },

  "scheduling": {
    "frequency": "weekly",
    "day_of_week": "Monday",
    "time_of_day_utc": "02:00",
    "timezone": "UTC",
    "run_immediately_on_deploy": true,
    "notify_on_failure": {
      "email": "dataops@research.university.edu",
      "slack_channel": "#health-insurance-scrape-alerts"
    }
  },

  "output_config": {
    "destination": "s3",
    "bucket_name": "research-health-insurance-pa",
    "file_prefix": "quotes/",
    "file_format": "parquet",
    "partition_by": ["carrier_id", "date"],
    "compression": "snappy",
    "metadata_inclusion": true,
    "post_processing": {
      "deduplicate": true,
      "add_ingest_timestamp": true
    }
  }
}
