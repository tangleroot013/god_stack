{
  "_metadata": {
    "description": "Health Insurance Carrier Target Configuration for Pennsylvania Academic Research Scraping",
    "version": "1.0",
    "last_updated": "2026-06-25",
    "research_scope": "Premium tracking, deductible trends, out-of-pocket maximum analysis, network coverage, plan availability",
    "state": "Pennsylvania",
    "insurance_type": "health",
    "instructions": "Add health insurance carrier URLs, quote form parameters, and extraction schema. Each target is processed with full stealth profile rotation."
  },

  "carriers": [
    {
      "carrier_id": "HIGHMARK_BCBS",
      "carrier_name": "Highmark Blue Cross Blue Shield Pennsylvania",
      "quote_url": "https://www.highmark.com/health-insurance/plans",
      "rate_lookup_url": "https://www.highmark.com/plans/individual-family",
      "quote_method": "POST",
      "form_params": {
        "zip_code": "19103",
        "age": "35",
        "gender": "F",
        "state": "PA",
        "household_size": 2,
        "household_income": "65000",
        "tobacco_user": false,
        "coverage_type": "individual",
        "plan_type": "PPO"
      },
      "extraction_schema": {
        "monthly_premium": {
          "css_selector": ".premium-amount, [data-monthly-cost]",
          "type": "float",
          "regex_pattern": "\\$(\\d+(?:,\\d{3})*\\.\\d{2})"
        },
        "annual_deductible": {
          "css_selector": ".deductible-value, [data-deductible]",
          "type": "float",
          "regex_pattern": "\\$(\\d+(?:,\\d{3})*\\.\\d{0,2})"
        },
        "out_of_pocket_max": {
          "css_selector": ".oop-max, [data-oop-maximum]",
          "type": "float",
          "regex_pattern": "\\$(\\d+(?:,\\d{3})*\\.\\d{0,2})"
        },
        "plan_type": {
          "css_selector": "[data-plan-type]",
          "type": "string"
        },
        "copay_primary_care": {
          "css_selector": ".copay-pcp, [data-copay-primary]",
          "type": "string",
          "regex_pattern": "\\$(\\d+)"
        },
        "network_type": {
          "css_selector": ".network-indicator",
          "type": "string"
        }
      },
      "request_config": {
        "min_delay_ms": 300,
        "max_delay_ms": 800,
        "referer": "https://www.google.com/search?q=health+insurance+pennsylvania",
        "accept_language": "en-US,en;q=0.9"
      },
      "target_metrics": [
        "monthly_premium",
        "annual_deductible",
        "out_of_pocket_max",
        "plan_type",
        "copay_primary_care",
        "network_coverage"
      ],
      "notes": "Highmark is the dominant regional BCBS carrier in PA. Moderate WAF sensitivity. Requires JavaScript rendering for rate tables. Store session cookies."
    },

    {
