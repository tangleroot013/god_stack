# =================================================================
# G.O.D. STACK - GLOBAL ORCHESTRATION DAEMON CONFIGURATION TEMPLATE
# =================================================================
# Copy this file to '.env' and populate it with your private keys.
# NEVER commit the actual '.env' file to your version control repository.

# --- NETWORK MASKING & INGRESS PROXIES ---
# Comma-separated list of premium proxy endpoints (HTTP/SOCKS5 supported)
OUTBOUND_PROXY_POOL="socks5://user:pass@127.0.0.1:9050,socks5://user:pass@127.0.0.1:9051"
PROXY_ROTATION_STRATEGY="round_robin" # Options: round_robin, random, latency_optimized

# --- STEALTH RUNTIME SIGNATURES ---
# Minimum and maximum jitter delay (in seconds) between sequential scraping hits
SCRAPE_JITTER_MIN=0.1
SCRAPE_JITTER_MAX=0.4
SPOOF_USER_AGENTS=true
CUSTOM_STEALTH_PROFILES_PATH="config/stealth_profiles.yaml"

# --- TARGET METRICS STORAGE ---
# Target endpoints or database configurations for extracted insurance datasets
INSURANCE_DB_PATH="cache.db"
UPSTREAM_TELEMETRY_API_KEY="REPLACE_WITH_YOUR_ACADEMIC_TOKEN"

# --- LATENCY PERFORMANCE SEVERITY ---
# Enforce strict performance window alerts
LATENCY_P95_MAX_THRESHOLD_MS=100
